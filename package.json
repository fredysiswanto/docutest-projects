{
  "name": "docu-test",
  "version": "1.0.0",
  "description": "Playwright and integration with docusaurus to help documentation testing and documentation out projects",
  "main": "index.js",
  "scripts": {
    "--prepare": "husky",
    "test": "playwright test && pnpm copy-report",
    "test:ui": "playwright test --ui",
    "test:api": "playwright test --ui --project=api",
    "test:ui-admin": "playwright test --ui --project=admin",
    "test:ui-client": "playwright test --ui --project=client",
    "copy-report": "rm -rf documentation/static/test-reports && cp -r reports documentation/static/test-reports",
    "report": "playwright show-report",
    "prettier:format": "npx prettier --write --ignore-unknown **/*",
    "prettier:check": "prettier --check --ignore-unknown **/*",
    "lint:fix": "eslint --fix */**/*.{js,ts}",
    "lint:check": "eslint */**/*.{js,ts} --no-warn-ignored"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/cli": "^0.1.7",
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.59.1",
    "@types/crypto-js": "^4.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.1",
    "ajv": "^8.18.0",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "eslint-plugin-ascii": "^2.0.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
